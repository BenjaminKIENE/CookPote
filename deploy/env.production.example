# ============================================================
# Cookpote Backend — Production Environment
# Copy to /var/www/cookpote/backend/.env and fill values.
# Generate secrets: cd backend && bash scripts/generate-secrets.sh
# NEVER commit this file.
# ============================================================

NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# ── Database ──────────────────────────────────────────────────
DATABASE_PATH=/var/www/cookpote/backend/data/cookpote.db

# ── JWT — min 32 chars each, DIFFERENT secrets ───────────────
JWT_ACCESS_SECRET=REPLACE_openssl_rand_-base64_32
JWT_REFRESH_SECRET=REPLACE_openssl_rand_-base64_32_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── AES-256-GCM key for TOTP secrets — base64, 44 chars ──────
# Generate: openssl rand -base64 33 | head -c 44
ENCRYPTION_KEY=REPLACE_44_CHAR_BASE64

# ── CSRF ──────────────────────────────────────────────────────
CSRF_SECRET=REPLACE_openssl_rand_-base64_32

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── SMTP Hostinger ────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@cookpote.fr
SMTP_PASS=REPLACE_EMAIL_PASSWORD
SMTP_FROM="Cookpote" <noreply@cookpote.fr>

# ── Storage ───────────────────────────────────────────────────
UPLOADS_PATH=/var/www/cookpote/backend/uploads

# ── App URLs ──────────────────────────────────────────────────
APP_URL=https://cookpote.fr
API_URL=https://cookpote.fr/api
