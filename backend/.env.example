# ============================================================
# Cookpote Backend — Environment Variables
# Copy to .env and fill in the values.
# Generate secrets with: bash scripts/generate-secrets.sh
# ============================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/cookpote.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Min 32 chars. Use: openssl rand -base64 32
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Encryption (AES-256-GCM for TOTP secrets) ────────────────────────────────
# MUST be base64-encoded 32 bytes (44 chars). Use: openssl rand -base64 33 | head -c 44
# WARNING: rotating this key requires re-encrypting all TOTP secrets in the DB
ENCRYPTION_KEY=REPLACE_WITH_44_CHAR_BASE64_KEY

# ── CSRF ──────────────────────────────────────────────────────────────────────
CSRF_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Anthropic API ─────────────────────────────────────────────────────────────
# NEVER log, NEVER expose to the frontend client
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── SMTP Hostinger ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@cookpote.fr
SMTP_PASS=REPLACE_WITH_EMAIL_PASSWORD
SMTP_FROM="Cookpote" <noreply@cookpote.fr>

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOADS_PATH=./uploads

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:4200
API_URL=http://localhost:3000
